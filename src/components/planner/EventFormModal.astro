---
import type { Client, EventType } from '../../types/planner';
import Icon from '../Icon.astro';

/**
 * Props del modal visual para crear eventos.
 */
interface Props {
  open: boolean;
  closeHref: string;
  clients: Client[];
  eventTypes: EventType[];
}

const { open, closeHref, clients, eventTypes } = Astro.props;
---

{
  open && (
    <div class="fixed inset-0 z-50 bg-slate-950/30 px-4 py-6 backdrop-blur-sm">
      <div class="mx-auto max-w-3xl rounded-[34px] border border-white/80 bg-white p-6 shadow-[0_40px_120px_-40px_rgba(15,23,42,0.45)] md:p-8">
        <div class="mb-6 flex items-start justify-between gap-4">
          <div>
            <p class="font-display text-3xl font-semibold text-slate-900">Nuevo evento</p>
            <p class="mt-2 text-sm text-slate-500">Formulario visual dividido por bloques de producción.</p>
          </div>
          <a
            href={closeHref}
            class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 text-slate-400 transition hover:bg-slate-50 hover:text-slate-700"
            aria-label="Cerrar modal"
          >
            <Icon name="close" size={16} />
          </a>
        </div>

        <div class="grid gap-6 lg:grid-cols-2">
          <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Información</p>
            <div class="mt-4 space-y-4">
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Título</span>
                <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none ring-0" value="Campaña Día del Padre" />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Empresa</span>
                <select class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none">
                  {clients.map((client) => <option>{client.name}</option>)}
                </select>
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Tipo de evento</span>
                <select class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none">
                  {eventTypes.map((type) => <option>{type.name}</option>)}
                </select>
              </label>
            </div>
          </section>

          <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Fecha</p>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Inicio</span>
                <input type="datetime-local" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none" value="2026-06-05T10:00" />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Fin</span>
                <input type="datetime-local" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none" value="2026-06-05T11:00" />
              </label>
            </div>
            <label class="mt-4 block">
              <span class="mb-2 block text-sm font-semibold text-slate-700">Estado</span>
              <select class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none">
                <option>Pendiente</option>
                <option selected>En revisión</option>
                <option>Publicado</option>
                <option>Confirmada</option>
                <option>Cancelado</option>
              </select>
            </label>
          </section>

          <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Producción</p>
            <label class="mt-4 block">
              <span class="mb-2 block text-sm font-semibold text-slate-700">Descripción</span>
              <textarea class="min-h-32 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none">Campaña especial para el Día del Padre. Incluir promociones en stories, reel y publicaciones.</textarea>
            </label>
          </section>

          <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Recursos</p>
            <div class="mt-4 space-y-4">
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Responsable</span>
                <input class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none" value="Laura Martínez" />
              </label>
              <label class="block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Color principal</span>
                <div class="flex gap-2">
                  {['#ff7a7a', '#5b8def', '#9b5cf6', '#7ad36c', '#4f46e5'].map((swatch, index) => (
                    <span class:list={['h-9 w-9 rounded-full border-4', index === 0 ? 'border-white shadow-lg ring-2 ring-slate-200' : 'border-transparent']} style={`background:${swatch};`} />
                  ))}
                </div>
              </label>
            </div>
          </section>
        </div>

        <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-end">
          <a href={closeHref} class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Cancelar</a>
          <button class="inline-flex items-center justify-center rounded-2xl border border-indigo-100 bg-indigo-50 px-5 py-3 text-sm font-semibold text-indigo-700 transition hover:bg-indigo-100">
            Guardar y crear otro
          </button>
          <button class="inline-flex items-center justify-center rounded-2xl bg-[linear-gradient(135deg,_#4338ca,_#4f46e5)] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:brightness-105">
            Guardar evento
          </button>
        </div>
      </div>
    </div>
  )
}
