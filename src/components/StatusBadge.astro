---
import type { StatusTone } from '../types/planner';

/**
 * Props del badge reutilizable para estados de eventos.
 */
interface Props {
  label: string;
  tone?: StatusTone;
}

const { label, tone = 'info' } = Astro.props;

/**
 * Clases visuales asociadas a cada tono de badge.
 */
const tones: Record<StatusTone, string> = {
  info: 'bg-blue-50 text-blue-700 ring-blue-100',
  warning: 'bg-amber-50 text-amber-700 ring-amber-100',
  success: 'bg-emerald-50 text-emerald-700 ring-emerald-100',
  mint: 'bg-lime-50 text-lime-700 ring-lime-100',
  muted: 'bg-slate-100 text-slate-600 ring-slate-200',
};
---

<span class:list={['inline-flex items-center rounded-full px-2.5 py-1 text-[11px] font-semibold ring-1 ring-inset', tones[tone]]}>
  {label}
</span>
