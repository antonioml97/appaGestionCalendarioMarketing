---
import { capitalize, formatShortWeekday } from '../../../lib/format';
import { buildHref } from '../../../lib/url';
import type { CalendarDayCell } from '../../../lib/calendar';
import type { ResolvedCalendarEvent } from '../../../types/planner';
import EventCard from './EventCard.astro';

/**
 * Props necesarias para renderizar la cuadricula mensual.
 */
interface Props {
  matrix: CalendarDayCell[][];
  eventsByDay: Map<string, ResolvedCalendarEvent[]>;
  selectedEventId?: string;
  searchParams: URLSearchParams;
}

const { matrix, eventsByDay, selectedEventId, searchParams } = Astro.props;

/**
 * Etiquetas de cabecera derivadas de la primera fila de la matriz.
 */
const weekdays = matrix[0]?.map((cell) => capitalize(formatShortWeekday(cell.date).replace('.', ''))) ?? [];
---

<div class="overflow-hidden rounded-[30px] border border-white/80 bg-white/96 shadow-[0_18px_40px_-30px_rgba(15,23,42,0.35)]">
  <div class="grid grid-cols-7 border-b border-slate-100 px-4 py-4 text-center text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">
    {weekdays.map((label) => <div>{label}</div>)}
  </div>

  <div class="grid grid-cols-7">
    {matrix.flat().map((day) => {
      const dayEvents = eventsByDay.get(day.key) ?? [];
      const createHref = buildHref('/calendar', searchParams, {
        modal: 'new-event',
        event: null,
        draftAt: new Date(
          day.date.getFullYear(),
          day.date.getMonth(),
          day.date.getDate(),
          9,
          0,
          0,
          0,
        ).toISOString(),
      });
      return (
        <div
          class:list={[
            'min-h-[152px] border-b border-r border-slate-100 p-3 transition hover:bg-indigo-50/40',
            !day.inCurrentMonth && 'bg-slate-50/60',
          ]}
        >
          <div class="mb-3 flex items-center justify-between">
            <a
              href={createHref}
              class:list={[
                'grid h-8 w-8 place-items-center rounded-full text-sm font-semibold transition hover:scale-105',
                day.isToday ? 'bg-indigo-600 text-white' : 'text-slate-700 hover:bg-indigo-50',
              ]}
              aria-label={`Crear evento el dia ${day.date.getDate()}`}
            >
              {day.date.getDate()}
            </a>
            {dayEvents.length > 2 && (
              <span class="text-[11px] font-semibold text-slate-400">+{dayEvents.length - 2}</span>
            )}
          </div>

          <div class="space-y-2">
            {dayEvents.slice(0, 2).map((event) => (
              <EventCard
                event={event}
                href={buildHref('/calendar', searchParams, {
                  event: event.id,
                  modal: null,
                  draftAt: null,
                })}
                selected={selectedEventId === event.id}
              />
            ))}
          </div>

          <div class="mt-3">
            <a
              href={createHref}
              class="flex min-h-9 items-center rounded-2xl border border-dashed border-slate-200 px-3 text-xs font-semibold text-slate-400 transition hover:border-indigo-200 hover:bg-indigo-50/60 hover:text-indigo-700"
            >
              Crear evento
            </a>
          </div>
        </div>
      );
    })}
  </div>
</div>
