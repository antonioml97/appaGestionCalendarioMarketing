---
import type { Client, EventType, PlannerUser, ResolvedCalendarEvent } from '../../../types/planner';
import Icon from '../../../components/Icon.astro';

interface Props {
  open: boolean;
  closeHref: string;
  clients: Client[];
  eventTypes: EventType[];
  currentUser: PlannerUser;
  event?: ResolvedCalendarEvent;
  redirectTo: string;
  draftStartsAt?: string;
}

const { open, closeHref, clients, eventTypes, currentUser, event, redirectTo, draftStartsAt } = Astro.props;
const selectedClient =
  clients.find((client) => client.id === event?.clientId) ?? clients[0];

const toDateTimeLocal = (value?: string) => {
  if (!value) return '';

  const date = new Date(value);
  const pad = (chunk: number) => String(chunk).padStart(2, '0');

  return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}`;
};

const getDraftEndAt = (value?: string) => {
  if (!value) return undefined;

  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return undefined;

  date.setHours(date.getHours() + 1);
  return date.toISOString();
};

const defaultStartsAt = event?.startsAt ?? draftStartsAt;
const defaultEndsAt = event?.endsAt ?? getDraftEndAt(draftStartsAt);
const canCreateEvent = clients.length > 0 && eventTypes.length > 0;
---

{
  open && (
    <div class="fixed inset-0 z-50 bg-slate-950/30 px-4 py-6 backdrop-blur-sm">
      <div class="mx-auto max-w-3xl rounded-[34px] border border-white/80 bg-white p-6 shadow-[0_40px_120px_-40px_rgba(15,23,42,0.45)] md:p-8">
        <div class="mb-6 flex items-start justify-between gap-4">
          <div>
            <p class="font-display text-3xl font-semibold text-slate-900">
              {event ? 'Editar evento' : 'Nuevo evento'}
            </p>
            <p class="mt-2 text-sm text-slate-500">
              Formulario persistente conectado al CRUD real del calendario.
            </p>
          </div>
          <a
            href={closeHref}
            class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 text-slate-400 transition hover:bg-slate-50 hover:text-slate-700"
            aria-label="Cerrar modal"
          >
            <Icon name="close" size={16} />
          </a>
        </div>

        {!canCreateEvent && (
          <div class="mb-6 rounded-[24px] border border-amber-100 bg-amber-50 px-4 py-3 text-sm text-amber-700">
            Necesitas al menos una empresa y un tipo de evento activos para crear eventos.
          </div>
        )}

        <form method="POST" action="/api/events">
          <input type="hidden" name="_action" value="save" />
          <input type="hidden" name="redirectTo" value={redirectTo} />
          {event && <input type="hidden" name="id" value={event.id} />}

          <div class="grid gap-6 lg:grid-cols-2">
            <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Información</p>
              <div class="mt-4 space-y-4">
                <label class="block">
                  <span class="mb-2 block text-sm font-semibold text-slate-700">Título</span>
                  <input
                    name="title"
                    required
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none ring-0"
                    value={event?.title ?? ''}
                  />
                </label>
                <label class="block">
                  <span class="mb-2 block text-sm font-semibold text-slate-700">Empresa</span>
                  <select
                    id="event-client-select"
                    name="clientId"
                    required
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none"
                  >
                    {clients.map((client) => (
                      <option
                        value={client.id}
                        selected={event?.clientId === client.id || (!event && selectedClient?.id === client.id)}
                        data-client-color={client.color}
                        data-client-name={client.name}
                      >
                        {client.name}
                      </option>
                    ))}
                  </select>
                </label>
                <label class="block">
                  <span class="mb-2 block text-sm font-semibold text-slate-700">Tipo de evento</span>
                  <select
                    name="eventTypeId"
                    required
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none"
                  >
                    {eventTypes.map((type) => (
                      <option value={type.id} selected={event?.eventTypeId === type.id}>
                        {type.name}
                      </option>
                    ))}
                  </select>
                </label>
              </div>
            </section>

            <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Fecha</p>
              <div class="mt-4 grid gap-4 sm:grid-cols-2">
                <label class="block">
                  <span class="mb-2 block text-sm font-semibold text-slate-700">Inicio</span>
                  <input
                    type="datetime-local"
                    name="startsAt"
                    required
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none"
                    value={toDateTimeLocal(defaultStartsAt)}
                  />
                </label>
                <label class="block">
                  <span class="mb-2 block text-sm font-semibold text-slate-700">Fin</span>
                  <input
                    type="datetime-local"
                    name="endsAt"
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none"
                    value={toDateTimeLocal(defaultEndsAt)}
                  />
                </label>
              </div>
              <label class="mt-4 block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Estado</span>
                <select
                  name="status"
                  class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none"
                >
                  {[
                    ['pending', 'Pendiente'],
                    ['in_progress', 'En revisión'],
                    ['published', 'Publicado'],
                    ['completed', 'Confirmada'],
                    ['cancelled', 'Cancelado'],
                  ].map(([value, label]) => (
                    <option value={value} selected={event?.status === value || (!event && value === 'pending')}>
                      {label}
                    </option>
                  ))}
                </select>
              </label>
            </section>

            <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Producción</p>
              <label class="mt-4 block">
                <span class="mb-2 block text-sm font-semibold text-slate-700">Descripción</span>
                <textarea
                  name="description"
                  class="min-h-32 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none"
                >{event?.description ?? ''}</textarea>
              </label>
            </section>

            <section class="rounded-[28px] border border-slate-100 bg-slate-50/70 p-5">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Recursos</p>
              <div class="mt-4 space-y-4">
                <label class="block">
                  <span class="mb-2 block text-sm font-semibold text-slate-700">Responsable</span>
                  <input
                    readonly
                    class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm outline-none"
                    value={`${currentUser.name} · ${currentUser.title}`}
                  />
                </label>
                <label class="block">
                  <span class="mb-2 block text-sm font-semibold text-slate-700">Color del evento</span>
                  <div class="rounded-2xl border border-slate-200 bg-white px-4 py-3">
                    <div class="flex items-center gap-3">
                      <span
                        id="event-client-color-preview"
                        class="h-8 w-8 rounded-full border-4 border-white shadow ring-1 ring-slate-200"
                        style={`background:${selectedClient?.color ?? '#4f46e5'};`}
                      />
                      <div>
                        <p class="text-sm font-semibold text-slate-800">Heredado de la empresa</p>
                        <p id="event-client-color-label" class="text-xs text-slate-500">
                          {selectedClient ? `${selectedClient.name} · ${selectedClient.color}` : 'Selecciona una empresa'}
                        </p>
                      </div>
                    </div>
                  </div>
                </label>
              </div>
            </section>
          </div>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a href={closeHref} class="inline-flex items-center justify-center rounded-2xl border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">Cancelar</a>
            <button
              disabled={!canCreateEvent}
              class="inline-flex items-center justify-center rounded-2xl bg-[linear-gradient(135deg,_#4338ca,_#4f46e5)] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 transition hover:brightness-105 disabled:cursor-not-allowed disabled:opacity-50"
            >
              {event ? 'Guardar cambios' : 'Guardar evento'}
            </button>
          </div>
        </form>
      </div>
    </div>
  )
}

<script>
  const clientSelect = document.querySelector('#event-client-select');
  const preview = document.querySelector('#event-client-color-preview');
  const label = document.querySelector('#event-client-color-label');

  const syncClientColor = () => {
    if (
      !(clientSelect instanceof HTMLSelectElement) ||
      !(preview instanceof HTMLElement) ||
      !(label instanceof HTMLElement)
    ) {
      return;
    }

    const selectedOption = clientSelect.selectedOptions[0];
    const color = selectedOption?.dataset.clientColor;
    const name = selectedOption?.dataset.clientName;

    if (!color || !name) {
      return;
    }

    preview.style.background = color;
    label.textContent = `${name} · ${color}`;
  };

  syncClientColor();
  clientSelect?.addEventListener('change', syncClientColor);
</script>
