---
import { hexToRgba } from '../../../lib/format';
import { toggleQueryValue, buildHref } from '../../../lib/url';
import type { Client, EventStatus, EventType } from '../../../types/planner';
import Icon from '../../../components/Icon.astro';

/**
 * Resumen agregado de carga semanal por cliente.
 */
interface WorkloadItem {
  clientId: string;
  total: number;
  percentage: number;
}

/**
 * Props del sidebar de filtros y resumen de actividad.
 */
interface Props {
  clients: Client[];
  eventTypes: EventType[];
  statuses: EventStatus[];
  selectedClientIds: string[];
  selectedTypeIds: string[];
  selectedStatuses: string[];
  searchParams: URLSearchParams;
  workload: WorkloadItem[];
}

const {
  clients,
  eventTypes,
  statuses,
  selectedClientIds,
  selectedTypeIds,
  selectedStatuses,
  searchParams,
  workload,
} = Astro.props;

/**
 * Etiquetas visibles para los estados filtrables en la UI.
 */
const statusLabels = {
  pending: 'Pendiente',
  in_progress: 'En revisión',
  completed: 'Confirmada',
  published: 'Publicado',
  cancelled: 'Cancelado',
};
---

<aside class="rounded-[30px] border border-white/80 bg-white/92 p-5 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)]">
  <div class="flex items-center justify-between">
    <div>
      <p class="text-sm font-semibold text-slate-900">Empresas</p>
      <p class="text-xs text-slate-500">Filtra por cliente activo</p>
    </div>
    <a
      href="/clients"
      class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 text-slate-500 transition hover:border-indigo-100 hover:bg-indigo-50 hover:text-indigo-700"
      aria-label="Gestionar empresas"
    >
      <Icon name="plus" size={16} />
    </a>
  </div>

  <div class="mt-4 space-y-2">
    {clients.map((client) => {
      const active = selectedClientIds.includes(client.id);
      return (
        <a
          href={toggleQueryValue('/calendar', searchParams, 'client', client.id)}
          class:list={[
            'flex items-center justify-between rounded-2xl border px-3 py-3 text-sm transition',
            active ? 'border-transparent bg-slate-50 shadow-sm' : 'border-transparent hover:bg-slate-50',
          ]}
        >
          <div class="flex min-w-0 items-center gap-3">
            <span
              class="h-3 w-3 rounded-full"
              style={`background:${client.color}; box-shadow:0 0 0 5px ${hexToRgba(client.color, 0.14)};`}
            />
            <span class="truncate font-medium text-slate-700">{client.name}</span>
          </div>
          {active && <span class="text-xs font-semibold text-indigo-700">Activo</span>}
        </a>
      );
    })}
  </div>

  <div class="mt-6 flex items-center justify-between">
    <div>
      <p class="text-sm font-semibold text-slate-900">Tipos de evento</p>
      <p class="text-xs text-slate-500">Icono + color suave</p>
    </div>
    <a
      href="/event-types"
      class="inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-slate-200 text-slate-500 transition hover:border-indigo-100 hover:bg-indigo-50 hover:text-indigo-700"
      aria-label="Gestionar tipos"
    >
      <Icon name="edit" size={16} />
    </a>
  </div>

  <div class="mt-4 space-y-2">
    {eventTypes.map((type) => {
      const active = selectedTypeIds.includes(type.id);
      return (
        <a
          href={toggleQueryValue('/calendar', searchParams, 'type', type.id)}
          class:list={[
            'flex items-center justify-between rounded-2xl border px-3 py-3 text-sm transition',
            active ? 'border-transparent bg-slate-50 shadow-sm' : 'border-transparent hover:bg-slate-50',
          ]}
        >
          <div class="flex items-center gap-3">
            <div
              class="flex h-8 w-8 items-center justify-center rounded-2xl"
              style={`background:${hexToRgba(type.color, 0.12)}; color:${type.color};`}
            >
              <Icon name={type.icon} size={15} />
            </div>
            <span class="font-medium text-slate-700">{type.name}</span>
          </div>
          {active && <span class="text-xs font-semibold text-indigo-700">Activo</span>}
        </a>
      );
    })}
  </div>

  <div class="mt-6">
    <p class="text-sm font-semibold text-slate-900">Estado</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {statuses.map((status) => {
        const active = selectedStatuses.includes(status);
        return (
          <a
            href={toggleQueryValue('/calendar', searchParams, 'status', status)}
            class:list={[
              'rounded-full px-3 py-2 text-xs font-semibold transition',
              active
                ? 'bg-indigo-50 text-indigo-700'
                : 'bg-slate-100 text-slate-500 hover:bg-slate-200 hover:text-slate-700',
            ]}
          >
            {statusLabels[status]}
          </a>
        );
      })}
    </div>
  </div>

  <div class="mt-6 rounded-[24px] border border-slate-100 bg-[linear-gradient(180deg,_#ffffff_0%,_#f8faff_100%)] p-4 shadow-inner">
    <div class="flex items-center justify-between">
      <div>
        <p class="text-sm font-semibold text-slate-900">Carga semanal</p>
        <p class="text-xs text-slate-500">Esta semana</p>
      </div>
      <Icon name="dashboard" class="text-indigo-500" size={18} />
    </div>

    <div class="mt-4 space-y-3">
      {workload.map((item) => {
        const client = clients.find((entry) => entry.id === item.clientId);
        if (!client) return null;
        return (
          <div>
            <div class="mb-1 flex items-center justify-between text-xs">
              <span class="font-medium text-slate-600">{client.name}</span>
              <span class="font-semibold text-slate-400">{item.percentage}%</span>
            </div>
            <div class="h-2 rounded-full bg-slate-100">
              <div
                class="h-2 rounded-full"
                style={`width:${item.percentage}%; background:${client.color};`}
              />
            </div>
          </div>
        );
      })}
    </div>

    <a
      href={buildHref('/dashboard', searchParams, {})}
      class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-indigo-700"
    >
      Ver reporte completo
      <Icon name="chevron-right" size={14} />
    </a>
  </div>
</aside>
