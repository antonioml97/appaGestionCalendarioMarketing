---
import Icon from '../../../components/Icon.astro';
import type { Client } from '../../../types/planner';

interface Props {
  open: boolean;
  client?: Client;
  closeHref: string;
  redirectTo?: string;
}

const {
  open,
  client,
  closeHref,
  redirectTo = '/clients',
} = Astro.props;
---

{
  open && (
    <div class="fixed inset-0 z-50 bg-slate-950/30 px-4 py-6 backdrop-blur-sm">
      <div class="mx-auto max-w-2xl rounded-[34px] border border-white/80 bg-white p-6 shadow-[0_40px_120px_-40px_rgba(15,23,42,0.45)] md:p-8">
        <div class="mb-6 flex items-start justify-between gap-4">
          <div>
            <p class="font-display text-3xl font-semibold text-slate-900">
              {client ? 'Editar empresa' : 'Nueva empresa'}
            </p>
            <p class="mt-2 text-sm text-slate-500">
              {client
                ? 'Actualiza la informacion visual y operativa de esta empresa.'
                : 'Crea una nueva empresa para empezar a planificar sus eventos.'}
            </p>
          </div>
          <a
            href={closeHref}
            class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 text-slate-400 transition hover:bg-slate-50 hover:text-slate-700"
            aria-label="Cerrar modal"
          >
            <Icon name="close" size={16} />
          </a>
        </div>

        <form method="POST" action="/api/clients" class="space-y-5">
          <input type="hidden" name="_action" value="save" />
          <input type="hidden" name="redirectTo" value={redirectTo} />
          {client && <input type="hidden" name="id" value={client.id} />}

          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Nombre</span>
            <input
              name="name"
              required
              value={client?.name ?? ''}
              class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
            />
          </label>

          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Color</span>
            <input
              type="color"
              name="color"
              value={client?.color ?? '#4f46e5'}
              class="h-14 w-full rounded-[22px] border border-slate-200 bg-white px-2 py-2"
            />
          </label>

          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Descripcion</span>
            <textarea
              name="description"
              class="min-h-32 w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
            >{client?.description ?? ''}</textarea>
          </label>

          <label class="flex items-center gap-3 rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-700">
            <input type="checkbox" name="active" checked={client ? client.active : true} />
            Empresa activa
          </label>

          <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
            <a
              href={closeHref}
              class="inline-flex items-center justify-center rounded-[22px] border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
            >
              Cancelar
            </a>
            <button class="inline-flex items-center justify-center gap-2 rounded-[22px] bg-[linear-gradient(135deg,_#4338ca,_#4f46e5)] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:brightness-105">
              <Icon name="edit" size={16} />
              {client ? 'Guardar cambios' : 'Crear empresa'}
            </button>
          </div>
        </form>
      </div>
    </div>
  )
}
