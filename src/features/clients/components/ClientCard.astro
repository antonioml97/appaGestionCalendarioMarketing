---
import Icon from '../../../components/Icon.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import { formatDayMonth, hexToRgba } from '../../../lib/format';
import type { Client, ResolvedCalendarEvent } from '../../../types/planner';

interface Props {
  client: Client;
  events: ResolvedCalendarEvent[];
}

const { client, events } = Astro.props;
const nextEvent = events.find((event) => new Date(event.startsAt) >= new Date());
---

<article class="rounded-[32px] border border-white/80 bg-white/95 p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)]">
  <div class="flex items-start justify-between gap-4">
    <div class="flex items-start gap-4">
      <div
        class="grid h-14 w-14 place-items-center rounded-[22px] text-white shadow-lg"
        style={`background:linear-gradient(135deg, ${client.color}, ${hexToRgba(client.color, 0.7)});`}
      >
        <Icon name="company" size={20} />
      </div>
      <div>
        <p class="font-display text-3xl font-semibold text-slate-950">{client.name}</p>
        <p class="mt-2 max-w-md text-sm leading-7 text-slate-500">
          {client.description || 'Sin descripcion.'}
        </p>
      </div>
    </div>
    <StatusBadge
      label={client.active ? 'Activa' : 'Inactiva'}
      tone={client.active ? 'success' : 'muted'}
    />
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-3">
    <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
      <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Eventos</p>
      <p class="mt-2 text-3xl font-semibold text-slate-900">{events.length}</p>
    </div>
    <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
      <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Pendientes</p>
      <p class="mt-2 text-3xl font-semibold text-slate-900">
        {events.filter((event) => event.status === 'pending').length}
      </p>
    </div>
    <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
      <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Proximo</p>
      <p class="mt-2 text-lg font-semibold text-slate-900">
        {nextEvent ? formatDayMonth(new Date(nextEvent.startsAt)) : 'Sin fecha'}
      </p>
    </div>
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    <a
      href={`/calendar?client=${client.id}`}
      class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-700"
    >
      Ver en calendario
      <Icon name="chevron-right" size={14} />
    </a>
    <a
      href={`/clients?edit=${client.id}`}
      class="inline-flex items-center gap-2 rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
    >
      <Icon name="edit" size={14} />
      Editar
    </a>
    <form
      method="POST"
      action="/api/clients"
      onsubmit="return confirm('Seguro que quieres borrar esta empresa y todos sus eventos?');"
    >
      <input type="hidden" name="_action" value="delete" />
      <input type="hidden" name="id" value={client.id} />
      <input type="hidden" name="redirectTo" value="/clients" />
      <button class="inline-flex items-center gap-2 rounded-full border border-rose-200 px-4 py-2 text-sm font-semibold text-rose-600 transition hover:bg-rose-50">
        <Icon name="trash" size={14} />
        Borrar
      </button>
    </form>
  </div>
</article>
