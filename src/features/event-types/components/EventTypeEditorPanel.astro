---
import Icon from '../../../components/Icon.astro';
import type { EventType, PlannerIconName } from '../../../types/planner';

interface Props {
  eventType?: EventType;
  availableIcons: PlannerIconName[];
}

const { eventType, availableIcons } = Astro.props;
---

<article class="rounded-[34px] border border-white/80 bg-white/95 p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)] lg:p-8">
  <p class="text-sm text-slate-500">Configuracion visual</p>
  <h1 class="mt-2 font-display text-4xl font-semibold text-slate-950">
    {eventType ? 'Editar tipo de evento' : 'Nuevo tipo de evento'}
  </h1>
  <p class="mt-3 max-w-2xl text-base leading-8 text-slate-600">
    Define las categorias del calendario con su color e icono, y manten el sistema organizado
    por tipo de accion.
  </p>

  <form method="POST" action="/api/event-types" class="mt-8 space-y-5">
    <input type="hidden" name="_action" value="save" />
    <input type="hidden" name="redirectTo" value="/event-types" />
    {eventType && <input type="hidden" name="id" value={eventType.id} />}

    <label class="block">
      <span class="mb-2 block text-sm font-semibold text-slate-700">Nombre</span>
      <input
        name="name"
        required
        value={eventType?.name ?? ''}
        class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
      />
    </label>

    <div class="grid gap-5 md:grid-cols-2">
      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">Color</span>
        <input
          type="color"
          name="color"
          value={eventType?.color ?? '#4f46e5'}
          class="h-14 w-full rounded-[22px] border border-slate-200 bg-white px-2 py-2"
        />
      </label>

      <label class="block">
        <span class="mb-2 block text-sm font-semibold text-slate-700">Icono</span>
        <select
          name="icon"
          class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
        >
          {availableIcons.map((iconName) => (
            <option
              value={iconName}
              selected={eventType?.icon === iconName || (!eventType && iconName === 'calendar')}
            >
              {iconName}
            </option>
          ))}
        </select>
      </label>
    </div>

    <label class="block">
      <span class="mb-2 block text-sm font-semibold text-slate-700">Descripcion</span>
      <textarea
        name="description"
        class="min-h-32 w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
      >{eventType?.description ?? ''}</textarea>
    </label>

    <label class="flex items-center gap-3 rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-700">
      <input type="checkbox" name="active" checked={eventType ? eventType.active : true} />
      Tipo activo
    </label>

    <div class="flex flex-col gap-3 sm:flex-row">
      <button class="inline-flex items-center justify-center gap-2 rounded-[22px] bg-[linear-gradient(135deg,_#4338ca,_#4f46e5)] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:brightness-105">
        <Icon name="edit" size={16} />
        {eventType ? 'Guardar cambios' : 'Crear tipo'}
      </button>
      {eventType && (
        <a
          href="/event-types"
          class="inline-flex items-center justify-center rounded-[22px] border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
        >
          Cancelar edicion
        </a>
      )}
    </div>
  </form>
</article>
