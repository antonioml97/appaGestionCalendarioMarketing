---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { getDemoCredentials } from '../config/env';

/**
 * Evita mostrar el login cuando ya existe una sesion valida.
 */
if (Astro.locals.currentUser) {
  return Astro.redirect('/calendar');
}

/**
 * Codigo de error simple para pintar feedback del formulario.
 */
const error = Astro.url.searchParams.get('error');

/**
 * Credenciales demo visibles en la pantalla de acceso.
 */
const { username: runtimeDemoUsername, password: runtimeDemoPassword } = getDemoCredentials();
---

<BaseLayout title="Login | Marketing Planner">
  <main class="mx-auto flex min-h-screen max-w-[640px] items-center px-4 py-8 lg:px-8">
    <section class="w-full rounded-[40px] border border-white/80 bg-white/94 p-6 shadow-[0_30px_100px_-38px_rgba(15,23,42,0.38)] md:p-8 lg:p-10">
      <div class="mb-8">
        <div class="mb-6 flex items-center gap-4">
          <div class="grid h-14 w-14 place-items-center rounded-[22px] bg-[linear-gradient(135deg,_#312e81,_#4f46e5_60%,_#7c3aed)] text-white shadow-lg">
            <span class="font-display text-2xl font-semibold">M</span>
          </div>
          <div>
            <p class="font-display text-2xl font-semibold text-slate-900">Marketing Planner</p>
            <p class="text-sm text-slate-500">Calendario editorial SaaS para agencias</p>
          </div>
        </div>

        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Acceso</p>
        <h2 class="mt-3 font-display text-4xl font-semibold text-slate-950">Entra al panel privado</h2>
        <p class="mt-3 text-base leading-7 text-slate-500">
          Accede con el usuario administrador configurado y entra directamente al planner conectado a base de datos.
        </p>
      </div>

      {error === '1' && (
        <div class="mb-6 rounded-[24px] border border-rose-100 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700">
          Credenciales no validas. Usa el acceso admin configurado abajo.
        </div>
      )}

      {error === 'server' && (
        <div class="mb-6 rounded-[24px] border border-amber-100 bg-amber-50 px-4 py-3 text-sm font-medium text-amber-800">
          El acceso no pudo completarse por un problema temporal del servidor. Si estas en Netlify, revisa `DATABASE_URL` para activar la persistencia completa.
        </div>
      )}

      <form method="POST" action="/api/login" class="space-y-5">
        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-slate-700">Usuario</span>
          <input
            type="text"
            name="username"
            value={runtimeDemoUsername}
            class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-800 outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-slate-700">Contrasena</span>
          <input
            type="password"
            name="password"
            value={runtimeDemoPassword}
            class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-800 outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
          />
        </label>
        <button class="inline-flex w-full items-center justify-center gap-2 rounded-[22px] bg-[linear-gradient(135deg,_#3730a3,_#4f46e5)] px-5 py-4 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:brightness-105">
          <Icon name="spark" size={18} />
          Entrar
        </button>
      </form>

      <div class="mt-8 rounded-[28px] border border-slate-100 bg-slate-50/80 p-5">
        <p class="text-sm font-semibold text-slate-800">Credenciales disponibles</p>
        <div class="mt-4 grid gap-3">
          <div class="rounded-2xl border border-white bg-white px-4 py-3 text-sm text-slate-600">
            <span class="font-semibold text-slate-900">Admin:</span> {runtimeDemoUsername} / {runtimeDemoPassword}
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
