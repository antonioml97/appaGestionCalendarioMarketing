---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

if (Astro.locals.currentUser) {
  return Astro.redirect('/calendar');
}

const error = Astro.url.searchParams.get('error');
---

<BaseLayout title="Login | Marketing Planner">
  <main class="mx-auto grid min-h-screen max-w-[1400px] items-center gap-10 px-4 py-8 lg:grid-cols-[1.05fr_0.95fr] lg:px-8">
    <section class="rounded-[40px] border border-white/70 bg-[linear-gradient(145deg,_rgba(255,255,255,0.94),_rgba(244,247,255,0.96))] p-6 shadow-[0_40px_120px_-40px_rgba(79,70,229,0.35)] backdrop-blur md:p-8 lg:p-10">
      <div class="mb-10 flex items-center gap-4">
        <div class="grid h-14 w-14 place-items-center rounded-[22px] bg-[linear-gradient(135deg,_#312e81,_#4f46e5_60%,_#7c3aed)] text-white shadow-lg">
          <span class="font-display text-2xl font-semibold">M</span>
        </div>
        <div>
          <p class="font-display text-2xl font-semibold text-slate-900">Marketing Planner</p>
          <p class="text-sm text-slate-500">Calendario editorial SaaS para agencias</p>
        </div>
      </div>

      <div class="max-w-xl">
        <span class="inline-flex rounded-full bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-700">
          Astro + TypeScript + Netlify + Drizzle
        </span>
        <h1 class="mt-6 font-display text-5xl leading-[1.05] font-semibold text-slate-950">
          Planifica campañas, clientes y producción sin perder contexto.
        </h1>
        <p class="mt-5 max-w-lg text-lg leading-8 text-slate-600">
          La demo replica el planner del briefing: calendario mensual premium, agenda móvil, filtros por empresa y detalle lateral listo para evolucionar a SaaS multi-tenant.
        </p>
      </div>

      <div class="mt-10 grid gap-4 sm:grid-cols-3">
        <article class="rounded-[28px] border border-white/80 bg-white/80 p-4">
          <div class="mb-3 grid h-11 w-11 place-items-center rounded-2xl bg-violet-50 text-violet-600">
            <Icon name="calendar" size={20} />
          </div>
          <p class="font-semibold text-slate-900">Contenido visible</p>
          <p class="mt-2 text-sm leading-6 text-slate-500">Calendario, agenda, panel de detalle y carga semanal.</p>
        </article>
        <article class="rounded-[28px] border border-white/80 bg-white/80 p-4">
          <div class="mb-3 grid h-11 w-11 place-items-center rounded-2xl bg-emerald-50 text-emerald-600">
            <Icon name="company" size={20} />
          </div>
          <p class="font-semibold text-slate-900">Multiempresa</p>
          <p class="mt-2 text-sm leading-6 text-slate-500">Clientes, tipos y eventos separados por organización.</p>
        </article>
        <article class="rounded-[28px] border border-white/80 bg-white/80 p-4">
          <div class="mb-3 grid h-11 w-11 place-items-center rounded-2xl bg-amber-50 text-amber-600">
            <Icon name="spark" size={20} />
          </div>
          <p class="font-semibold text-slate-900">Responsive real</p>
          <p class="mt-2 text-sm leading-6 text-slate-500">En móvil la experiencia principal es agenda, no miniatura.</p>
        </article>
      </div>
    </section>

    <section class="rounded-[40px] border border-white/80 bg-white/94 p-6 shadow-[0_30px_100px_-38px_rgba(15,23,42,0.38)] md:p-8 lg:p-10">
      <div class="mb-8">
        <p class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Acceso demo</p>
        <h2 class="mt-3 font-display text-4xl font-semibold text-slate-950">Entra al panel privado</h2>
        <p class="mt-3 text-base leading-7 text-slate-500">
          He dejado un login funcional con cookie de sesión para que el flujo se sienta más real desde el primer clic.
        </p>
      </div>

      {error && (
        <div class="mb-6 rounded-[24px] border border-rose-100 bg-rose-50 px-4 py-3 text-sm font-medium text-rose-700">
          Credenciales no válidas. Usa uno de los accesos demo indicados abajo.
        </div>
      )}

      <form method="POST" action="/api/login" class="space-y-5">
        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-slate-700">Email</span>
          <input
            type="email"
            name="email"
            value="laura@planner.demo"
            class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-800 outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
          />
        </label>
        <label class="block">
          <span class="mb-2 block text-sm font-semibold text-slate-700">Contraseña</span>
          <input
            type="password"
            name="password"
            value="demo123"
            class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-800 outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
          />
        </label>
        <button class="inline-flex w-full items-center justify-center gap-2 rounded-[22px] bg-[linear-gradient(135deg,_#3730a3,_#4f46e5)] px-5 py-4 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:brightness-105">
          <Icon name="spark" size={18} />
          Entrar a la demo
        </button>
      </form>

      <div class="mt-8 rounded-[28px] border border-slate-100 bg-slate-50/80 p-5">
        <p class="text-sm font-semibold text-slate-800">Credenciales disponibles</p>
        <div class="mt-4 grid gap-3">
          <div class="rounded-2xl border border-white bg-white px-4 py-3 text-sm text-slate-600">
            <span class="font-semibold text-slate-900">Admin:</span> laura@planner.demo / demo123
          </div>
          <div class="rounded-2xl border border-white bg-white px-4 py-3 text-sm text-slate-600">
            <span class="font-semibold text-slate-900">Gestor:</span> diego@planner.demo / demo123
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
