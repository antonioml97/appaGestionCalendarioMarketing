---
import AppShell from '../components/AppShell.astro';
import Icon from '../components/Icon.astro';
import EventDetailPanel from '../components/planner/EventDetailPanel.astro';
import EventFormModal from '../components/planner/EventFormModal.astro';
import MobileAgenda from '../components/planner/MobileAgenda.astro';
import MonthlyCalendar from '../components/planner/MonthlyCalendar.astro';
import SidebarFilters from '../components/planner/SidebarFilters.astro';
import WeekCalendar from '../components/planner/WeekCalendar.astro';
import DayTimeline from '../components/planner/DayTimeline.astro';
import { getOrganizationBundle } from '../db/repository';
import {
  addDays,
  addMonths,
  eventsForDate,
  eventsForWeek,
  getMonthMatrix,
  groupEventsByDay,
  isSameDay,
  parseDateParam,
  startOfWeek,
} from '../lib/calendar';
import { capitalize, formatMonthYear } from '../lib/format';
import {
  applyEventFilters,
  getWeeklyWorkload,
  resolveEvents,
} from '../lib/planner';
import { buildHref } from '../lib/url';
import type { CalendarView, EventStatus } from '../types/planner';

const currentUser = Astro.locals.currentUser!;
const dataset = await getOrganizationBundle(currentUser);
const resolvedEvents = resolveEvents(dataset);
const searchParams = Astro.url.searchParams;

const validViews: CalendarView[] = ['month', 'week', 'day', 'agenda'];
const view = validViews.includes(searchParams.get('view') as CalendarView)
  ? (searchParams.get('view') as CalendarView)
  : 'month';
const focusDate = parseDateParam(searchParams.get('date'));
const selectedClientIds = searchParams.getAll('client');
const selectedTypeIds = searchParams.getAll('type');
const selectedStatuses = searchParams.getAll('status') as EventStatus[];
const search = searchParams.get('search') ?? '';
const modal = searchParams.get('modal');
const mobileScope = searchParams.get('scope') ?? 'month';

const filteredEvents = applyEventFilters(resolvedEvents, {
  clientIds: selectedClientIds,
  typeIds: selectedTypeIds,
  statuses: selectedStatuses,
  search,
});

const selectedEventId = searchParams.get('event') ?? undefined;
const selectedEvent =
  filteredEvents.find((event) => event.id === selectedEventId) ??
  resolvedEvents.find((event) => event.id === selectedEventId);

const monthMatrix = getMonthMatrix(focusDate);
const eventsByDay = new Map(
  monthMatrix.flat().map((day) => [day.key, eventsForDate(filteredEvents, day.date)]),
);
const weekItems = eventsForWeek(filteredEvents, focusDate);
const dayEvents = eventsForDate(filteredEvents, focusDate);

const agendaEvents = filteredEvents.filter((event) => {
  const eventDate = new Date(event.startsAt);
  if (mobileScope === 'day') return isSameDay(eventDate, focusDate);
  if (mobileScope === 'week') {
    const weekStart = startOfWeek(focusDate);
    const weekEnd = addDays(weekStart, 7);
    return eventDate >= weekStart && eventDate < weekEnd;
  }
  return (
    eventDate.getFullYear() === focusDate.getFullYear() &&
    eventDate.getMonth() === focusDate.getMonth()
  );
});

const agendaGroups = groupEventsByDay(agendaEvents);
const workload = getWeeklyWorkload(filteredEvents, startOfWeek(focusDate));

const previousDate =
  view === 'month' ? addMonths(focusDate, -1) : view === 'week' ? addDays(focusDate, -7) : addDays(focusDate, -1);
const nextDate =
  view === 'month' ? addMonths(focusDate, 1) : view === 'week' ? addDays(focusDate, 7) : addDays(focusDate, 1);

const clearEventHref = buildHref('/calendar', searchParams, { event: null, modal: null });
const closeModalHref = buildHref('/calendar', searchParams, { modal: null });
const eventEditHref = selectedEvent
  ? buildHref('/calendar', searchParams, { modal: 'edit-event', event: selectedEvent.id })
  : '#';
const redirectTo = buildHref('/calendar', searchParams, { modal: null });
const showEventModal =
  modal === 'new-event' || (modal === 'edit-event' && Boolean(selectedEvent));
const modalEvent = modal === 'edit-event' ? selectedEvent : undefined;
---

<AppShell title="Calendario | Marketing Planner" currentPath="/calendar" currentUser={currentUser} organization={dataset.organization}>
  <section class="md:hidden">
    <div class="mb-4 flex items-center justify-between rounded-[28px] border border-white/80 bg-white/90 px-4 py-4 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.34)]">
      <button class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-slate-50 text-slate-600">
        <Icon name="menu" size={18} />
      </button>
      <div class="text-center">
        <p class="font-display text-xl font-semibold text-slate-900">{capitalize(formatMonthYear(focusDate))}</p>
      </div>
      <a href={buildHref('/calendar', searchParams, { modal: 'new-event' })} class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-indigo-600 text-white shadow-lg shadow-indigo-500/25">
        <Icon name="plus" size={18} />
      </a>
    </div>

    <div class="mb-4 rounded-[28px] border border-white/80 bg-white/95 p-2 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.34)]">
      <div class="grid grid-cols-3 gap-2">
        {[
          { label: 'Hoy', scope: 'day' },
          { label: 'Semana', scope: 'week' },
          { label: 'Mes', scope: 'month' },
        ].map((item) => (
          <a
            href={buildHref('/calendar', searchParams, { scope: item.scope })}
            class:list={[
              'rounded-2xl px-3 py-2 text-center text-sm font-semibold transition',
              mobileScope === item.scope ? 'bg-indigo-50 text-indigo-700' : 'text-slate-500',
            ]}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>

    <MobileAgenda groups={agendaGroups} selectedEventId={selectedEvent?.id} searchParams={searchParams} />

    {selectedEvent && (
      <div class="fixed inset-x-0 bottom-24 z-40 px-4">
        <EventDetailPanel
          event={selectedEvent}
          closeHref={clearEventHref}
          editHref={eventEditHref}
          redirectTo={redirectTo}
          mobile
        />
      </div>
    )}
  </section>

  <section class="hidden md:block">
    <div class="grid gap-6 xl:grid-cols-[280px_minmax(0,1fr)_340px]">
      <SidebarFilters
        clients={dataset.clients}
        eventTypes={dataset.eventTypes}
        statuses={['pending', 'in_progress', 'completed', 'published', 'cancelled']}
        selectedClientIds={selectedClientIds}
        selectedTypeIds={selectedTypeIds}
        selectedStatuses={selectedStatuses}
        searchParams={searchParams}
        workload={workload}
      />

      <div class="space-y-6">
        <div class="rounded-[32px] border border-white/80 bg-white/92 p-5 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)] lg:p-6">
          <div class="grid gap-4 xl:grid-cols-[minmax(280px,360px)_1fr] xl:items-center">
            <form method="GET" action="/calendar" class="relative min-w-0 flex-1">
              <Icon name="search" class="pointer-events-none absolute left-4 top-1/2 -translate-y-1/2 text-slate-400" size={17} />
              <input
                type="search"
                name="search"
                value={search}
                placeholder="Buscar eventos, empresas..."
                class="w-full rounded-[22px] border border-slate-200 bg-slate-50 py-3 pl-12 pr-4 text-sm text-slate-800 outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
              />
              {selectedClientIds.map((id) => <input type="hidden" name="client" value={id} />)}
              {selectedTypeIds.map((id) => <input type="hidden" name="type" value={id} />)}
              {selectedStatuses.map((status) => <input type="hidden" name="status" value={status} />)}
              <input type="hidden" name="view" value={view} />
              <input type="hidden" name="date" value={focusDate.toISOString()} />
            </form>

            <div class="flex flex-wrap items-center justify-end gap-3">
              <div class="flex items-center gap-2 rounded-[22px] border border-slate-200 bg-white px-3 py-2">
                <a href={buildHref('/calendar', searchParams, { date: previousDate.toISOString() })} class="inline-flex h-10 w-10 items-center justify-center rounded-2xl text-slate-500 transition hover:bg-slate-50 hover:text-slate-900">
                  <Icon name="chevron-left" size={16} />
                </a>
                <p class="min-w-40 text-center font-display text-2xl font-semibold text-slate-900">{capitalize(formatMonthYear(focusDate))}</p>
                <a href={buildHref('/calendar', searchParams, { date: nextDate.toISOString() })} class="inline-flex h-10 w-10 items-center justify-center rounded-2xl text-slate-500 transition hover:bg-slate-50 hover:text-slate-900">
                  <Icon name="chevron-right" size={16} />
                </a>
              </div>

              <div class="flex items-center gap-2 rounded-[22px] border border-slate-200 bg-slate-50 p-1">
                {[
                  { label: 'Mes', view: 'month' },
                  { label: 'Semana', view: 'week' },
                  { label: 'Día', view: 'day' },
                  { label: 'Agenda', view: 'agenda' },
                ].map((item) => (
                  <a
                    href={buildHref('/calendar', searchParams, { view: item.view })}
                    class:list={[
                      'rounded-2xl px-4 py-2 text-sm font-semibold transition',
                      view === item.view ? 'bg-white text-indigo-700 shadow-sm' : 'text-slate-500 hover:text-slate-800',
                    ]}
                  >
                    {item.label}
                  </a>
                ))}
              </div>

              <a
                href={buildHref('/calendar', searchParams, { modal: 'new-event' })}
                class="inline-flex items-center gap-2 rounded-[22px] bg-[linear-gradient(135deg,_#4338ca,_#4f46e5)] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:brightness-105"
              >
                <Icon name="plus" size={16} />
                Nuevo evento
              </a>
            </div>
          </div>
        </div>

        {view === 'week' && (
          <WeekCalendar weekItems={weekItems} selectedEventId={selectedEvent?.id} searchParams={searchParams} />
        )}
        {view === 'day' && (
          <DayTimeline
            focusDate={focusDate}
            events={dayEvents}
            selectedEventId={selectedEvent?.id}
            searchParams={searchParams}
          />
        )}
        {view === 'agenda' && (
          <MobileAgenda
            groups={groupEventsByDay(filteredEvents)}
            selectedEventId={selectedEvent?.id}
            searchParams={searchParams}
          />
        )}
        {view === 'month' && (
          <MonthlyCalendar
            matrix={monthMatrix}
            eventsByDay={eventsByDay}
            selectedEventId={selectedEvent?.id}
            searchParams={searchParams}
          />
        )}
      </div>

      <div class="hidden xl:block">
        <EventDetailPanel
          event={selectedEvent}
          closeHref={clearEventHref}
          editHref={eventEditHref}
          redirectTo={redirectTo}
        />
      </div>
    </div>
  </section>

  <EventFormModal
    open={showEventModal}
    closeHref={closeModalHref}
    clients={dataset.clients.filter((client) => client.active)}
    eventTypes={dataset.eventTypes.filter((type) => type.active)}
    currentUser={currentUser}
    event={modalEvent}
    redirectTo={redirectTo}
  />
</AppShell>
