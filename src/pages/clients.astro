---
import AppShell from '../components/AppShell.astro';
import Icon from '../components/Icon.astro';
import StatusBadge from '../components/StatusBadge.astro';
import { getOrganizationBundle } from '../db/repository';
import { formatDayMonth, hexToRgba } from '../lib/format';
import { resolveEvents } from '../lib/planner';

const currentUser = Astro.locals.currentUser!;
const dataset = await getOrganizationBundle(currentUser);
const resolvedEvents = resolveEvents(dataset);
const editId = Astro.url.searchParams.get('edit');
const editingClient = dataset.clients.find((client) => client.id === editId);
---

<AppShell title="Empresas | Marketing Planner" currentPath="/clients" currentUser={currentUser} organization={dataset.organization}>
  <section class="grid gap-6">
    <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
      <article class="rounded-[34px] border border-white/80 bg-white/95 p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)] lg:p-8">
        <p class="text-sm text-slate-500">CRUD real de empresas</p>
        <h1 class="mt-2 font-display text-4xl font-semibold text-slate-950">
          {editingClient ? 'Editar empresa' : 'Nueva empresa'}
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-8 text-slate-600">
          Los cambios ya se guardan en la base de datos. Si borras una empresa, también se borran sus eventos asociados.
        </p>

        <form method="POST" action="/api/clients" class="mt-8 space-y-5">
          <input type="hidden" name="_action" value="save" />
          <input type="hidden" name="redirectTo" value="/clients" />
          {editingClient && <input type="hidden" name="id" value={editingClient.id} />}

          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Nombre</span>
            <input
              name="name"
              required
              value={editingClient?.name ?? ''}
              class="w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
            />
          </label>

          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Color</span>
            <input
              type="color"
              name="color"
              value={editingClient?.color ?? '#4f46e5'}
              class="h-14 w-full rounded-[22px] border border-slate-200 bg-white px-2 py-2"
            />
          </label>

          <label class="block">
            <span class="mb-2 block text-sm font-semibold text-slate-700">Descripción</span>
            <textarea
              name="description"
              class="min-h-32 w-full rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm outline-none transition focus:border-indigo-200 focus:bg-white focus:ring-4 focus:ring-indigo-50"
            >{editingClient?.description ?? ''}</textarea>
          </label>

          <label class="flex items-center gap-3 rounded-[22px] border border-slate-200 bg-slate-50 px-4 py-4 text-sm text-slate-700">
            <input type="checkbox" name="active" checked={editingClient ? editingClient.active : true} />
            Empresa activa
          </label>

          <div class="flex flex-col gap-3 sm:flex-row">
            <button class="inline-flex items-center justify-center gap-2 rounded-[22px] bg-[linear-gradient(135deg,_#4338ca,_#4f46e5)] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:brightness-105">
              <Icon name="edit" size={16} />
              {editingClient ? 'Guardar cambios' : 'Crear empresa'}
            </button>
            {editingClient && (
              <a href="/clients" class="inline-flex items-center justify-center rounded-[22px] border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                Cancelar edición
              </a>
            )}
          </div>
        </form>
      </article>

      <article class="rounded-[34px] border border-white/80 bg-white/95 p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)] lg:p-8">
        <p class="text-sm text-slate-500">Resumen</p>
        <h2 class="mt-2 font-display text-4xl font-semibold text-slate-950">Empresas activas</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-3">
          <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Total</p>
            <p class="mt-2 text-3xl font-semibold text-slate-900">{dataset.clients.length}</p>
          </div>
          <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Activas</p>
            <p class="mt-2 text-3xl font-semibold text-slate-900">{dataset.clients.filter((client) => client.active).length}</p>
          </div>
          <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Eventos</p>
            <p class="mt-2 text-3xl font-semibold text-slate-900">{dataset.events.length}</p>
          </div>
        </div>
      </article>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
      {dataset.clients.map((client) => {
        const clientEvents = resolvedEvents.filter((event) => event.clientId === client.id);
        const nextEvent = clientEvents.find((event) => new Date(event.startsAt) >= new Date());
        return (
          <article class="rounded-[32px] border border-white/80 bg-white/95 p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)]">
            <div class="flex items-start justify-between gap-4">
              <div class="flex items-start gap-4">
                <div
                  class="grid h-14 w-14 place-items-center rounded-[22px] text-white shadow-lg"
                  style={`background:linear-gradient(135deg, ${client.color}, ${hexToRgba(client.color, 0.7)});`}
                >
                  <Icon name="company" size={20} />
                </div>
                <div>
                  <p class="font-display text-3xl font-semibold text-slate-950">{client.name}</p>
                  <p class="mt-2 max-w-md text-sm leading-7 text-slate-500">{client.description || 'Sin descripción.'}</p>
                </div>
              </div>
              <StatusBadge label={client.active ? 'Activa' : 'Inactiva'} tone={client.active ? 'success' : 'muted'} />
            </div>

            <div class="mt-6 grid gap-4 sm:grid-cols-3">
              <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
                <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Eventos</p>
                <p class="mt-2 text-3xl font-semibold text-slate-900">{clientEvents.length}</p>
              </div>
              <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
                <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Pendientes</p>
                <p class="mt-2 text-3xl font-semibold text-slate-900">
                  {clientEvents.filter((event) => event.status === 'pending').length}
                </p>
              </div>
              <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
                <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Próximo</p>
                <p class="mt-2 text-lg font-semibold text-slate-900">
                  {nextEvent ? formatDayMonth(new Date(nextEvent.startsAt)) : 'Sin fecha'}
                </p>
              </div>
            </div>

            <div class="mt-6 flex flex-wrap gap-3">
              <a href={`/calendar?client=${client.id}`} class="inline-flex items-center gap-2 rounded-full bg-indigo-50 px-4 py-2 text-sm font-semibold text-indigo-700">
                Ver en calendario
                <Icon name="chevron-right" size={14} />
              </a>
              <a href={`/clients?edit=${client.id}`} class="inline-flex items-center gap-2 rounded-full border border-slate-200 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-50">
                <Icon name="edit" size={14} />
                Editar
              </a>
              <form method="POST" action="/api/clients" onsubmit="return confirm('¿Seguro que quieres borrar esta empresa y todos sus eventos?');">
                <input type="hidden" name="_action" value="delete" />
                <input type="hidden" name="id" value={client.id} />
                <input type="hidden" name="redirectTo" value="/clients" />
                <button class="inline-flex items-center gap-2 rounded-full border border-rose-200 px-4 py-2 text-sm font-semibold text-rose-600 transition hover:bg-rose-50">
                  <Icon name="trash" size={14} />
                  Borrar
                </button>
              </form>
            </div>
          </article>
        );
      })}
    </div>
  </section>
</AppShell>
