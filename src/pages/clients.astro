---
import AppShell from '../components/AppShell.astro';
import Icon from '../components/Icon.astro';
import { getOrganizationBundle } from '../db/repository';
import ClientCard from '../features/clients/components/ClientCard.astro';
import ClientFormModal from '../features/clients/components/ClientFormModal.astro';
import { resolveEvents } from '../lib/planner';

const currentUser = Astro.locals.currentUser!;
const dataset = await getOrganizationBundle(currentUser);
const resolvedEvents = resolveEvents(dataset);
const editId = Astro.url.searchParams.get('edit');
const editingClient = dataset.clients.find((client) => client.id === editId);
const isCreateModalOpen = Astro.url.searchParams.get('modal') === 'new';
const isClientModalOpen = isCreateModalOpen || Boolean(editingClient);
---

<AppShell
  title="Empresas | Marketing Planner"
  currentPath="/clients"
  currentUser={currentUser}
  organization={dataset.organization}
>
  <section class="grid gap-6">
    <div class="grid gap-6 xl:grid-cols-[0.95fr_1.05fr]">
      <article class="rounded-[34px] border border-white/80 bg-white/95 p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)] lg:p-8">
        <p class="text-sm text-slate-500">Gestion de cartera</p>
        <h1 class="mt-2 font-display text-4xl font-semibold text-slate-950">Empresas</h1>
        <p class="mt-3 max-w-2xl text-base leading-8 text-slate-600">
          Organiza tus marcas, controla su actividad y accede rapido a sus eventos asociados desde
          una sola vista.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="/clients?modal=new"
            class="inline-flex items-center justify-center gap-2 rounded-[22px] bg-[linear-gradient(135deg,_#4338ca,_#4f46e5)] px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:brightness-105"
          >
            <Icon name="plus" size={16} />
            Nueva empresa
          </a>
          <a
            href="/calendar"
            class="inline-flex items-center justify-center rounded-[22px] border border-slate-200 px-5 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-50"
          >
            Volver al calendario
          </a>
        </div>
      </article>

      <article class="rounded-[34px] border border-white/80 bg-white/95 p-6 shadow-[0_18px_40px_-28px_rgba(15,23,42,0.35)] lg:p-8">
        <p class="text-sm text-slate-500">Resumen</p>
        <h2 class="mt-2 font-display text-4xl font-semibold text-slate-950">Empresas activas</h2>
        <div class="mt-6 grid gap-4 sm:grid-cols-3">
          <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Total</p>
            <p class="mt-2 text-3xl font-semibold text-slate-900">{dataset.clients.length}</p>
          </div>
          <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Activas</p>
            <p class="mt-2 text-3xl font-semibold text-slate-900">
              {dataset.clients.filter((client) => client.active).length}
            </p>
          </div>
          <div class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-4">
            <p class="text-xs uppercase tracking-[0.16em] text-slate-400">Eventos</p>
            <p class="mt-2 text-3xl font-semibold text-slate-900">{dataset.events.length}</p>
          </div>
        </div>
      </article>
    </div>

    <div class="grid gap-5 lg:grid-cols-2">
      {dataset.clients.map((client) => (
        <ClientCard
          client={client}
          events={resolvedEvents.filter((event) => event.clientId === client.id)}
        />
      ))}
    </div>

    <ClientFormModal open={isClientModalOpen} client={editingClient} closeHref="/clients" />
  </section>
</AppShell>
